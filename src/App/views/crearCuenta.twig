{% extends "layouts/base.twig" %}

{% block title %}Crear cuenta{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="/assets/css/crear-cuenta.css">
{% endblock %}

{% block scripts %}
    <script src="/assets/js/constructorElementos.js"></script>
    <script src="/assets/js/crear-cuenta.js"></script>
{% endblock %}

{% block main %}
    <h2>Crear cuenta</h2>

    {% if error is defined and error is not null %}
        <p style="color: red; background: #fee; padding: 10px; border: 1px solid red; border-radius: 5px; text-align: center; max-width: 400px; margin: 10px auto;">
            {{ error|e }}
        </p>
    {% endif %}

    <form action="/crearCuenta" id="form-crear-cuenta" method="post" novalidate>
        <fieldset>
        <legend>Datos personales:</legend>
            <label for="nombre_apellido">Nombre y apellido</label>
            <input type="text" id="nombre_apellido" name="nombre_apellido" placeholder="ej.: Maria Perez">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" placeholder="ej.:tuemail@email.com">
            <label for="telefono">Telefono (opcional)</label>
            <input type="tel" id="telefono" name="telefono" placeholder="ej.:+54 011 11111111">
            <label for="contraseña">Contraseña</label>
            <input type="password" id="contraseña" name="contraseña" placeholder="ej.:tucontraseña">
            <label for="ccontraseña">Confirmar contraseña</label>
            <input type="password" id="ccontraseña" name="ccontraseña" placeholder="ej.:tucontraseña">
        </fieldset>
        <button type="submit">Crear cuenta</button>
    </form>
    <div class="form-link">
        <p>¿Ya tienes una cuenta? <a href="/inicio-sesion">Iniciar sesión</a></p>
    </div>
{% endblock %}
