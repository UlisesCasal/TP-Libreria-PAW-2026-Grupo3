{% set esPersonal = _session.usuario is defined and _session.usuario.rol == 'personal' %}
<header>
    <a href="/">
        <img src="/assets/img/Logo_Violeta2.JPG" alt="Logo Violeta">
    </a>
    <h1>Libreria</h1>
    <nav>
        <ul>
            <li><a href="/">Inicio</a></li>
            <li><a href="/catalogo">Catálogo</a></li>
            {% if not esPersonal %}
                <li><a href="/mis-compras" style="white-space: nowrap;">Mis compras</a></li>
            {% endif %}
            {% if esPersonal %}
                <li><a href="/crear-libro">Crear libro</a></li>
                <li><a href="/pedidos" style="white-space: nowrap;">Historial de compras</a></li>
            {% endif %}
        </ul>
        <form action="/catalogo" method="get" role="search">
            <label for="busqueda-libros">Buscar libro:</label>
            <input type="search" id="busqueda-libros" name="q" placeholder="Título, autor o género">
            <button type="submit">Buscar</button>
        </form>
        <div class="nav-acciones">
            {% if _session.usuario %}
                <span class="user-greeting">Hola, <strong>{{ _session.usuario.nombre|split(' ')|first }}</strong></span>
                <a href="/cerrar-sesion" class="btn-logout">Salir</a>
            {% else %}
                <a href="/crearCuenta">Creá tu cuenta</a>
                <a href="/inicio-sesion">Ingresá</a>
            {% endif %}
            {% if not esPersonal %}
                <a href="/carrito" class="btn-carrito-nav">Carrito</a>
            {% endif %}
        </div>
    </nav>
</header>
